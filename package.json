{
  "name": "@cryptoapis-io/mcp-market-data",
  "version": "0.2.0",
  "description": "MCP server for cryptocurrency asset prices, exchange rates, and market metadata via Crypto APIs",
  "license": "MIT",
  "author": "Crypto APIs, Inc.",
  "repository": {
    "type": "git",
    "url": "https://github.com/CryptoAPIs-io/cryptoapis-mcp-market-data.git"
  },

    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "node -e \"console.log('lint: add eslint if you want')\"",
    "test": "node -e \"console.log('test: add later')\"",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "@types/express": "^5.0.6"
  }
